---
import ProjectLayout from "../../layouts/ProjectLayout.astro";
---

<ProjectLayout>
  <section class="mb-12">
    <div class="flex flex-col gap-6">
      <div>
        <h1 class="text-4xl sm:text-5xl font-bold mb-4">Laser-Cut Japanese Pagoda</h1>
        <p class="text-lg text-gray-700 max-w-3xl">
          Designed and fabricated a multi-story lantern inspired by traditional Japanese pagoda architecture.
          The piece combines precision laser-cut wood joinery, acrylic light panels, and surface engraving —
          blending digital fabrication with physical craft.
        </p>
        <ul class="flex flex-wrap gap-3 mt-5">
          <li class="bg-gray-900 text-white px-3 py-1 rounded-md text-sm">Laser Cutting</li>
          <li class="bg-gray-900 text-white px-3 py-1 rounded-md text-sm">Design for Fabrication</li>
          <li class="bg-gray-900 text-white px-3 py-1 rounded-md text-sm">Wood Joinery</li>
          <li class="bg-gray-900 text-white px-3 py-1 rounded-md text-sm">Acrylic</li>
        </ul>
      </div>

      <figure class="rounded-lg overflow-hidden shadow-md border border-gray-200">
        <img
          src="/images/makerspace work/lantern-1.JPG"
          alt="Japanese pagoda lantern"
          class="w-full h-auto object-cover"
        />
        <figcaption class="px-3 py-1.5 text-xs text-gray-400 font-mono">lantern-1.JPG</figcaption>
      </figure>
    </div>
  </section>

  <section class="mb-12">
    <h2 class="text-2xl font-bold mb-6">Photos</h2>
    <div class="grid grid-cols-2 sm:grid-cols-3 gap-4">
      {[
        "lantern-2.JPG",
        "lantern-3.JPG",
        "lantern-4.JPG",
        "lantern-5.jpg",
        "lantern-6.jpg",
        "lantern-8.JPG",
        "lantern-9.jpg",
        "lantern-10.jpg",
        "lantern-11.jpg",
        "lantern-12.jpg",
        "lantern-13.jpg",
        "lantern-14.jpg",
        "lantern-15.jpg",
        "lantern-16.jpg",
        "lantern-17.jpg",
        "lantern-18.jpg",
        "lantern-19.jpg",
        "lantern-20.jpg",
        "lantern-21.jpg",
      ].map((filename) => (
        <figure class="rounded-lg overflow-hidden border border-gray-200 shadow-sm">
          <img
            src={`/images/makerspace work/${filename}`}
            alt={filename}
            class="w-full h-48 object-cover"
            loading="lazy"
          />
          <figcaption class="px-2 py-1 text-xs text-gray-400 font-mono">{filename}</figcaption>
        </figure>
      ))}
    </div>
  </section>
</ProjectLayout>
