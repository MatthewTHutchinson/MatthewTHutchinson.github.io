---
import ProjectLayout from "../../layouts/ProjectLayout.astro";
---

<ProjectLayout>
  <section class="mb-12">
    <div class="flex flex-col gap-6">
      <div>
        <h1 class="text-4xl sm:text-5xl font-bold mb-4">Laser-Cut Maps</h1>
        <p class="text-lg text-gray-700 max-w-3xl">
          Topographic and city maps fabricated using laser-cut wood and acrylic.
          Each piece translates geographic data into layered physical form — designed in vector software
          and cut with precision at the UCLA Makerspace.
        </p>
        <ul class="flex flex-wrap gap-3 mt-5">
          <li class="bg-gray-900 text-white px-3 py-1 rounded-md text-sm">Laser Cutting</li>
          <li class="bg-gray-900 text-white px-3 py-1 rounded-md text-sm">Vector Design</li>
          <li class="bg-gray-900 text-white px-3 py-1 rounded-md text-sm">Wood & Acrylic</li>
          <li class="bg-gray-900 text-white px-3 py-1 rounded-md text-sm">Design for Fabrication</li>
        </ul>
      </div>

      <figure class="rounded-lg overflow-hidden shadow-md border border-gray-200">
        <img
          src="/images/makerspace work/sf-map-1.jpeg"
          alt="Laser-cut San Francisco map"
          class="w-full h-auto object-cover"
        />
        <figcaption class="px-3 py-1.5 text-xs text-gray-400 font-mono">sf-map-1.jpeg</figcaption>
      </figure>
    </div>
  </section>

  <section class="mb-12">
    <h2 class="text-2xl font-bold mb-2">San Francisco Maps</h2>
    <p class="text-gray-500 text-sm mb-6 font-mono">sf-map series</p>
    <div class="grid grid-cols-2 sm:grid-cols-3 gap-4">
      {[
        "sf-map-2.JPG",
        "sf-map-3.JPG",
        "sf-map-4.JPG",
        "sf-map-5.jpg",
        "sf-map-6.jpg",
      ].map((filename) => (
        <figure class="rounded-lg overflow-hidden border border-gray-200 shadow-sm">
          <img
            src={`/images/makerspace work/${filename}`}
            alt={filename}
            class="w-full h-48 object-cover"
            loading="lazy"
          />
          <figcaption class="px-2 py-1 text-xs text-gray-400 font-mono">{filename}</figcaption>
        </figure>
      ))}
    </div>
  </section>

  <section class="mb-12">
    <h2 class="text-2xl font-bold mb-2">UCLA Campus Map</h2>
    <p class="text-gray-500 text-sm mb-6 font-mono">ucla-map series</p>
    <div class="grid grid-cols-2 sm:grid-cols-3 gap-4">
      {[
        "ucla-map.JPG",
        "ucla-map-2.jpg",
        "ucla-map-3.JPG",
        "ucla-map-4.JPG",
        "ucla-map-5.jpg",
      ].map((filename) => (
        <figure class="rounded-lg overflow-hidden border border-gray-200 shadow-sm">
          <img
            src={`/images/makerspace work/${filename}`}
            alt={filename}
            class="w-full h-48 object-cover"
            loading="lazy"
          />
          <figcaption class="px-2 py-1 text-xs text-gray-400 font-mono">{filename}</figcaption>
        </figure>
      ))}
    </div>
  </section>
</ProjectLayout>
