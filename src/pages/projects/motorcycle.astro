---
import ProjectLayout from "../../layouts/ProjectLayout.astro";
---

<ProjectLayout>
  <section class="mb-12">
    <div class="flex flex-col gap-6">
      <div>
        <h1 class="text-4xl sm:text-5xl font-bold mb-4">Motorcycle Maintenance & Modifications</h1>
        <p class="text-lg text-gray-700 max-w-3xl">
          Ongoing maintenance on my Suzuki SV650. Work includes valve clearance inspections, oil changes,
          coolant flush, brake fluid flush, and exhaust swap. Done from the service manual.
        </p>
        <ul class="flex flex-wrap gap-3 mt-5">
          <li class="bg-gray-900 text-white px-3 py-1 rounded-md text-sm">Mechanical Systems</li>
          <li class="bg-gray-900 text-white px-3 py-1 rounded-md text-sm">Diagnostics</li>
          <li class="bg-gray-900 text-white px-3 py-1 rounded-md text-sm">Engine Work</li>
          <li class="bg-gray-900 text-white px-3 py-1 rounded-md text-sm">Tools & Torque Specs</li>
        </ul>
      </div>

      <figure class="rounded-lg overflow-hidden shadow-md border border-gray-200">
        <img
          src="/images/mtc/IMG_0533.JPG"
          alt="Suzuki SV650"
          class="w-full h-auto"
        />
        <figcaption class="px-3 py-1.5 text-xs text-gray-400 font-mono">IMG_0533.JPG</figcaption>
      </figure>
    </div>
  </section>

  <section class="mb-12">
    <h2 class="text-2xl font-bold mb-6">Photos</h2>
    <div class="grid grid-cols-2 sm:grid-cols-3 gap-4">
      {[
        "mtc-valves-1.JPG",
        "mtc-valves-2.JPG",
        "mtc-valves-3.JPG",
        "mtc-oil-change.JPG",
        "IMG_0031.JPG",
        "IMG_0529.JPG",
        "IMG_0531.JPG",
        "IMG_0534.JPG",
        "IMG_1487.JPG",
        "IMG_1488.JPG",
        "IMG_3138.JPG",
        "IMG_7544.JPG",
        "IMG_7814.JPG",
      ].map((filename) => (
        <figure class="rounded-lg overflow-hidden border border-gray-200 shadow-sm">
          <img
            src={`/images/mtc/${filename}`}
            alt={filename}
            class="w-full h-auto"
            loading="lazy"
          />
          <figcaption class="px-2 py-1 text-xs text-gray-400 font-mono">{filename}</figcaption>
        </figure>
      ))}
    </div>
  </section>
</ProjectLayout>
